{
  "name": "contact",
  "module": "crm",
  "label": "Contact",
  "fields": {
    "name":    { "type": "string", "required": true, "max": 200 },
    "email":   { "type": "email" },
    "phone":   { "type": "string", "max": 20 },
    "company": { "type": "string", "max": 200 },
    "notes":   { "type": "text" },
    "tags":    { "type": "many2many", "model": "tag" }
  },
  "record_rules": [
    { "groups": ["crm.user"], "domain": [["created_by", "=", "{{user.id}}"]] },
    { "groups": ["crm.manager"], "domain": [] }
  ]
}
