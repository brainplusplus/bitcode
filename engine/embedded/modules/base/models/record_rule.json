{
  "name": "record_rule",
  "module": "base",
  "label": "Record Rule",
  "fields": {
    "name":            { "type": "string", "required": true, "unique": true, "max": 100 },
    "model_name":      { "type": "string", "required": true, "max": 100 },
    "group_names":     { "type": "string", "max": 500 },
    "domain_filter":   { "type": "json" },
    "can_read":        { "type": "boolean", "default": true },
    "can_create":      { "type": "boolean", "default": true },
    "can_write":       { "type": "boolean", "default": true },
    "can_delete":      { "type": "boolean", "default": false },
    "is_global":       { "type": "boolean", "default": false },
    "active":          { "type": "boolean", "default": true },
    "module":          { "type": "string", "max": 100 },
    "modified_source": { "type": "string", "max": 20, "default": "json" }
  }
}
