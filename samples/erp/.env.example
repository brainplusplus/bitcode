# BitCode Engine - Environment Variables
# Copy to .env and edit as needed.
# .env overrides config file values. OS env vars override .env.

# Server
PORT=8080
MODULE_DIR=modules
JWT_SECRET=change-me-in-production-32chars!

# Database (sqlite, postgres, mysql)
DB_DRIVER=sqlite
DB_SQLITE_PATH=bitcode.db
# DB_DRIVER=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=bitcode
# DB_PASSWORD=bitcode
# DB_NAME=bitcode
# DB_SSLMODE=disable

# Cache (memory, redis)
CACHE_DRIVER=memory
# CACHE_DRIVER=redis
# REDIS_URL=redis://localhost:6379

# Multi-tenancy
TENANT_ENABLED=false
TENANT_STRATEGY=header
TENANT_HEADER=X-Tenant-ID
