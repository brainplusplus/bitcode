{
  "name": "user",
  "module": "base",
  "label": "User",
  "fields": {
    "username":      { "type": "string", "required": true, "unique": true, "max": 100 },
    "email":         { "type": "email", "required": true, "unique": true },
    "password_hash": { "type": "string", "max": 255 },
    "last_login":    { "type": "datetime" }
  },
  "record_rules": [
    { "groups": ["base.user"], "domain": [["id", "=", "{{user.id}}"]] },
    { "groups": ["base.admin"], "domain": [] }
  ]
}
