{
  "name": "hrm.officer",
  "label": "HR / Officer",
  "category": "HR",
  "implies": ["hrm.user"],
  "access": {
    "employee":      ["select", "read", "write", "create", "print", "email", "report", "export", "clone"],
    "department":    ["select", "read", "write", "create"],
    "job_position":  ["select", "read", "write", "create", "export"],
    "leave_request": ["select", "read", "write", "create", "print", "export"]
  },
  "rules": [
    { "name": "hrm_officer_all_employees", "model": "employee", "domain": [] },
    { "name": "hrm_officer_all_leaves", "model": "leave_request", "domain": [] }
  ],
  "menus": ["hrm/dashboard", "hrm/employees", "hrm/departments", "hrm/positions", "hrm/leaves", "hrm/leave-calendar"],
  "comment": "HR Officer. Can manage employees, departments, positions, and all leave requests."
}
