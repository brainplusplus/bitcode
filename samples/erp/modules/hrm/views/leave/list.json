{
  "name": "leave_list",
  "type": "list",
  "model": "leave_request",
  "title": "Leave Requests",
  "fields": ["employee_id", "leave_type", "start_date", "end_date", "days", "status"],
  "filters": ["status", "leave_type"],
  "sort": { "field": "start_date", "order": "desc" },
  "actions": [
    { "label": "Approve", "process": "approve_leave", "permission": "hrm.leave.approve", "visible": "status == 'submitted'", "variant": "primary" },
    { "label": "Reject",  "process": "reject_leave",  "permission": "hrm.leave.approve", "visible": "status == 'submitted'", "variant": "danger" }
  ]
}
