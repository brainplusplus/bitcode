{
  "name": "country",
  "module": "crm",
  "label": "Country",
  "primary_key": {
    "strategy": "natural_key",
    "field": "iso_code"
  },
  "fields": {
    "iso_code":    { "type": "string", "required": true, "unique": true, "max": 3, "label": "ISO Code" },
    "name":        { "type": "string", "required": true, "max": 100, "label": "Country Name" },
    "phone_code":  { "type": "string", "max": 10, "label": "Phone Code" }
  },
  "indexes": [
    ["name"]
  ]
}
